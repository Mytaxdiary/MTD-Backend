# Application
NODE_ENV=development
PORT=3500

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=mtd_user
DB_PASSWORD=your_password_here   # leave empty if local MySQL has no password
DB_NAME=mtd_db

# Alternatively use a full connection URL (for ORMs like Prisma / TypeORM)
# DATABASE_URL=mysql://mtd_user:your_password_here@localhost:3306/mtd_db

# Frontend URL (used for CORS in production)
FRONTEND_URL=http://localhost:3000

# Rate limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Security (10–14 recommended; higher = slower hashing but more secure)
BCRYPT_ROUNDS=10

# Mail / SMTP
# Leave MAIL_HOST blank in development to use console-only logging
# For Gmail: MAIL_HOST=smtp.gmail.com, MAIL_PORT=587, MAIL_SECURE=false, MAIL_USER=your@gmail.com, MAIL_PASS=app_password
# For SES: MAIL_HOST=email-smtp.eu-west-1.amazonaws.com, MAIL_PORT=587
MAIL_HOST=
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASS=
MAIL_FROM=noreply@yourdomain.co.uk
MAIL_FROM_NAME=NewEffect MTD ITSA

# Auth — JWT (TODO: set strong secrets before auth phase goes live)
JWT_SECRET=change_this_to_a_long_random_secret_min_32_chars
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=change_this_to_another_long_random_secret_min_32_chars
REFRESH_TOKEN_EXPIRES_IN=7d

# HMRC OAuth (Sandbox) — register app at https://developer.service.hmrc.gov.uk
HMRC_BASE_URL=https://test-api.service.hmrc.gov.uk
HMRC_AUTH_BASE_URL=https://test-www.tax.service.gov.uk
HMRC_CLIENT_ID=
HMRC_CLIENT_SECRET=
# Must match exactly what is registered in HMRC Developer Hub
HMRC_REDIRECT_URI=http://localhost:3000/settings/hmrc/callback
HMRC_SCOPE=read:sent-invitations write:sent-invitations read:self-assessment read:check-relationship write:relationships
# 64-char hex key for AES-256-GCM token encryption (optional in sandbox, required in prod)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
HMRC_ENCRYPTION_KEY=
# Fraud prevention (WEB_APP_VIA_SERVER) — server adds Gov-* headers on HMRC API calls
HMRC_VENDOR_PRODUCT_NAME=NewEffect MTD ITSA
HMRC_VENDOR_VERSION=mtd-api=1.0.0&mtd-app=1.0.0
# Your API server's public IPv4 (required for validator — not 127.0.0.1)
# Find yours: curl -4 https://api.ipify.org
HMRC_VENDOR_PUBLIC_IP=
# key=value format (required if set); omit entirely if you have no license id yet
# HMRC_VENDOR_LICENSE_IDS=mtd-itsa=your-hmrc-software-license-id
# Local dev only: fallback client TCP port when browser cannot detect it
HMRC_DEV_CLIENT_PUBLIC_PORT=12345
