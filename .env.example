# Application
NODE_ENV=development
PORT=3500

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=mtd_user
DB_PASSWORD=your_password_here   # leave empty if local MySQL has no password
DB_NAME=mtd_db

# Alternatively use a full connection URL (for ORMs like Prisma / TypeORM)
# DATABASE_URL=mysql://mtd_user:your_password_here@localhost:3306/mtd_db

# Frontend URL (used for CORS in production)
FRONTEND_URL=http://localhost:3000

# Rate limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Security (10–14 recommended; higher = slower hashing but more secure)
BCRYPT_ROUNDS=10

# Mail / SMTP
# Leave MAIL_HOST blank in development to use console-only logging
# For Gmail: MAIL_HOST=smtp.gmail.com, MAIL_PORT=587, MAIL_SECURE=false, MAIL_USER=your@gmail.com, MAIL_PASS=app_password
# For SES: MAIL_HOST=email-smtp.eu-west-1.amazonaws.com, MAIL_PORT=587
MAIL_HOST=
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASS=
MAIL_FROM=noreply@yourdomain.co.uk
MAIL_FROM_NAME=NewEffect MTD ITSA

# Auth — JWT (TODO: set strong secrets before auth phase goes live)
JWT_SECRET=change_this_to_a_long_random_secret_min_32_chars
JWT_EXPIRES_IN=1d
REFRESH_TOKEN_SECRET=change_this_to_another_long_random_secret_min_32_chars
REFRESH_TOKEN_EXPIRES_IN=7d
